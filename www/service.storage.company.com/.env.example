APP_NAME=object-storage-service
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://file.hxcbox.cn
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_SLACK_WEBHOOK_URL=

DB_CONNECTION=sqlite
DB_DATABASE=/absolute/path/to/database/database.sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=
DB_PASSWORD=

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
REDIS_QUEUE=default
QUEUE_RETRY_AFTER=300

WECHAT_MINI_PROGRAM_APP_ID=
WECHAT_MINI_PROGRAM_APP_SECRET=
WECHAT_MINI_PROGRAM_SESSION_URL=https://api.weixin.qq.com/sns/jscode2session
WECHAT_LOGIN_MOCK=false

VERIFICATION_CODE_WEBHOOK_URL=
VERIFICATION_CODE_WEBHOOK_TOKEN=
VERIFICATION_CODE_TIMEOUT=10
VERIFICATION_CODE_MAIL_ENABLED=false
VERIFICATION_CODE_MAIL_HOST=smtp.exmail.qq.com
VERIFICATION_CODE_MAIL_PORT=465
VERIFICATION_CODE_MAIL_ENCRYPTION=ssl
VERIFICATION_CODE_MAIL_USERNAME=
VERIFICATION_CODE_MAIL_PASSWORD=
VERIFICATION_CODE_MAIL_FROM_ADDRESS=
VERIFICATION_CODE_MAIL_FROM_NAME=守护者max
VERIFICATION_CODE_MAIL_TIMEOUT=15

# 公共对象存储服务域名，* 表示不限制域名
SERVICES_STORAGE_DOMAIN=file.hxcbox.cn
SERVICE_APP_ID=antifraud
SERVICE_SECRET=
SERVICE_AUTH_TIMESTAMP_TOLERANCE=300

# 上传限制
UPLOAD_MAX_FILE_SIZE=104857600

# 默认存储：tencent_cos / cloudflare_r2
OBJECT_STORAGE_DEFAULT_DISK=tencent_cos

# 腾讯云 COS，endpoint 示例：https://cos.ap-guangzhou.myqcloud.com
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_BUCKET=
TENCENT_COS_ENDPOINT=
TENCENT_COS_CDN_HOST=
TENCENT_COS_PATH_STYLE=false

# Cloudflare R2，endpoint 示例：https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_HOST=https://file.hxcbox.cn
R2_PATH_STYLE=false

WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_MERCHANT_SERIAL_NO=
WECHAT_PAY_MERCHANT_PRIVATE_KEY=
WECHAT_PAY_MERCHANT_PRIVATE_KEY_PATH=
WECHAT_PAY_PLATFORM_CERTIFICATE=
WECHAT_PAY_PLATFORM_CERTIFICATE_PATH=
WECHAT_PAY_NOTIFY_URL=https://file.hxcbox.cn/service/api/v1/payment/wechat/notify
WECHAT_PAY_API_BASE_URL=https://api.mch.weixin.qq.com
WECHAT_PAY_MOCK=false
