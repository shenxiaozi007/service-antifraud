APP_NAME=object-storage-service
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_SLACK_WEBHOOK_URL=

DB_CONNECTION=sqlite
DB_DATABASE=/absolute/path/to/database/database.sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=
DB_PASSWORD=

CACHE_DRIVER=file
QUEUE_CONNECTION=sync

# 公共对象存储服务域名，* 表示不限制域名
SERVICES_STORAGE_DOMAIN=*

# 上传限制
UPLOAD_MAX_FILE_SIZE=104857600

# 默认存储：tencent_cos / cloudflare_r2
OBJECT_STORAGE_DEFAULT_DISK=tencent_cos

# 腾讯云 COS，endpoint 示例：https://cos.ap-guangzhou.myqcloud.com
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_REGION=ap-guangzhou
TENCENT_COS_BUCKET=
TENCENT_COS_ENDPOINT=
TENCENT_COS_CDN_HOST=
TENCENT_COS_PATH_STYLE=false

# Cloudflare R2，endpoint 示例：https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_BUCKET=
R2_ENDPOINT=
R2_PUBLIC_HOST=
R2_PATH_STYLE=false
