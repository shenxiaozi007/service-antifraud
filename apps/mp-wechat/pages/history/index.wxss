.title.small {
  font-size: 42rpx;
}

.filters {
  display: flex;
  gap: 14rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
}

.filter {
  flex-shrink: 0;
  padding: 16rpx 26rpx;
  border-radius: 30rpx;
  background: #ffffff;
  color: #66706a;
  font-size: 26rpx;
}

.filter.active {
  background: #1f8a5b;
  color: #ffffff;
}

.record-title {
  flex: 1;
  min-width: 0;
  font-weight: 700;
  line-height: 1.4;
}
