<view class="page">
  <view class="section row">
    <view class="title small">历史记录</view>
    <view class="tag" bindtap="loadRecords">刷新</view>
  </view>

  <view class="filters">
    <view class="filter {{filter === '' ? 'active' : ''}}" data-filter="" bindtap="changeFilter">全部</view>
    <view class="filter {{filter === 'high' ? 'active' : ''}}" data-filter="high" bindtap="changeFilter">高风险</view>
    <view class="filter {{type === 'image' ? 'active' : ''}}" data-type="image" bindtap="changeType">图片</view>
    <view class="filter {{type === 'audio' ? 'active' : ''}}" data-type="audio" bindtap="changeType">录音</view>
  </view>

  <view class="card">
    <view wx:if="{{!records.length}}" class="empty">还没有分析记录</view>
    <block wx:for="{{records}}" wx:key="id">
      <view class="list-item" data-id="{{item.id}}" bindtap="goReport">
        <view class="row">
          <view class="record-title">{{item.title}}</view>
          <view class="tag {{item.riskClass}}">{{item.riskLabel}}</view>
        </view>
        <view class="muted">{{item.type === 'image' ? '帮您看' : '帮您听'}} · {{item.created_at}} · {{item.cost_points}}点</view>
      </view>
    </block>
  </view>
</view>
