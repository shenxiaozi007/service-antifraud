<view class="page">
  <view class="section">
    <view class="title">录音前提醒</view>
    <view class="subtitle">请将电话外放，或让手机靠近正在沟通的人声。系统会分析对话中的风险话术，仅作风险提醒参考。</view>
  </view>

  <view class="card recorder">
    <view class="timer">{{durationText}}</view>
    <view class="muted">{{recording ? '正在录音' : audioPath ? '录音已就绪' : '当前计费：10点/分钟'}}</view>
    <view class="button secondary" wx:if="{{!recording && !audioPath}}" bindtap="startRecord">开始录音</view>
    <view class="button secondary" wx:if="{{recording}}" bindtap="stopRecord">结束录音</view>
    <view class="button ghost" wx:if="{{audioPath && !recording}}" bindtap="resetRecord">重新录音</view>
  </view>

  <view class="card section">
    <view class="row">
      <view class="feature-title">对话文本</view>
      <view class="tag medium">联调用</view>
    </view>
    <textarea class="textarea" placeholder="可粘贴录音转写，如：不要告诉家人，把验证码发给我" value="{{text}}" bindinput="onTextInput"></textarea>
  </view>

  <view class="cost">不足 1 分钟按 1 分钟计算</view>
  <view class="button {{canSubmit ? '' : 'disabled'}}" bindtap="submit">结束并分析</view>
</view>
